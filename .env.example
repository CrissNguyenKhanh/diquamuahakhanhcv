# Easiest on Vercel: same key from web3forms.com — exposed in client bundle (allowed by Web3Forms).
# Add this in Vercel → Environment Variables → Redeploy (required so Vite embeds it at build time).
# VITE_WEB3FORMS_ACCESS_KEY=

# Optional: server-only key for api/contact.js (no VITE_ prefix)
# WEB3FORMS_ACCESS_KEY=

# Optional mailto fallback
# VITE_CONTACT_EMAIL=quockhanhdz295@gmail.com
